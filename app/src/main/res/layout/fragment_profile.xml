<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:padding="16dp">

    <TextView
        android:text="Profile"
        android:textStyle="bold" android:textSize="20sp"
        android:layout_width="wrap_content" android:layout_height="wrap_content"/>

    <TextView
        android:text="User: (local device)"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:paddingTop="8dp"/>

    <View
        android:layout_width="match_parent" android:layout_height="1dp"
        android:background="#DDD" android:layout_marginTop="16dp" />

    <TextView
        android:text="App Settings" android:textStyle="bold"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:paddingTop="16dp"/>

    <Switch
        android:id="@+id/swShake"
        android:text="Enable shake detection"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:paddingTop="8dp"/>

    <Switch
        android:id="@+id/swVolume"
        android:text="Require Volume+ with shake"
        android:layout_width="match_parent" android:layout_height="wrap_content"/>
</LinearLayout>